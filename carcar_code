static esp_err_t cmd_handler(httpd_req_t *req) {
    char query[64];
    char buf[32];

    if (httpd_req_get_url_query_str(req, query, sizeof(query)) != ESP_OK) {
        httpd_resp_set_type(req, "text/plain");
        return httpd_resp_send(req, "OK", 2);
    }

    // Direction servo: left=PULSE_MIN, mid=PULSE_MID, right=PULSE_MAX
    if (httpd_query_key_value(query, "dir", buf, sizeof(buf)) == ESP_OK) {
        if (strcmp(buf, "left") == 0)
            ledcWrite(SERVO_DIR_PIN, PULSE_MIN);
        else if (strcmp(buf, "right") == 0)
            ledcWrite(SERVO_DIR_PIN, PULSE_MAX);
        else
            ledcWrite(SERVO_DIR_PIN, PULSE_MID);
    }

    // Fan angle servo: 0-100% → PULSE_MIN-PULSE_MAX
    if (httpd_query_key_value(query, "fan", buf, sizeof(buf)) == ESP_OK) {
        int val = constrain(atoi(buf), 0, 100);
        ledcWrite(SERVO_FAN_PIN, map(val, 0, 100, PULSE_MIN, PULSE_MAX));
    }

    // ESC throttle: 0-100% → PULSE_MIN-PULSE_MAX (1000-2000µs, 50Hz)
    if (httpd_query_key_value(query, "thr", buf, sizeof(buf)) == ESP_OK) {
        int val = constrain(atoi(buf), 0, 100);
        ledcWrite(ESC_PIN, map(val, 0, 100, PULSE_MIN, PULSE_MAX));
    }

    // Drive: fwd → D1 max / D2 min; bwd → D1 min / D2 max; stop → both mid
    if (httpd_query_key_value(query, "drive", buf, sizeof(buf)) == ESP_OK) {
        if (strcmp(buf, "fwd") == 0) {
            ledcWrite(SERVO_DRIVE1_PIN, PULSE_MAX);
            ledcWrite(SERVO_DRIVE2_PIN, PULSE_MIN);
        } else if (strcmp(buf, "bwd") == 0) {
            ledcWrite(SERVO_DRIVE1_PIN, PULSE_MIN);
            ledcWrite(SERVO_DRIVE2_PIN, PULSE_MAX);
        } else {
            ledcWrite(SERVO_DRIVE1_PIN, PULSE_MID);
            ledcWrite(SERVO_DRIVE2_PIN, PULSE_MID);
        }
    }

    // Light toggle
    if (httpd_query_key_value(query, "light", buf, sizeof(buf)) == ESP_OK)
        digitalWrite(LIGHT_PIN, strcmp(buf, "1") == 0 ? HIGH : LOW);

    httpd_resp_set_type(req, "text/plain");
    return httpd_resp_send(req, "OK", 2);
}

static esp_err_t stream_handler(httpd_req_t *req) {
    camera_fb_t *fb = NULL;
    esp_err_t res = ESP_OK;
    char part_buf[64];

    httpd_resp_set_type(req, "multipart/x-mixed-replace;boundary=123456789000000000000987654321");

    while (true) {
        fb = esp_camera_fb_get();
        if (!fb) {
            res = ESP_FAIL;
        } else {
            size_t hlen = snprintf(part_buf, 64,
                "Content-Type: image/jpeg\r\nContent-Length: %u\r\n\r\n", fb->len);
            res = httpd_resp_send_chunk(req, part_buf, hlen);
            if (res == ESP_OK) res = httpd_resp_send_chunk(req, (const char *)fb->buf, fb->len);
            if (res == ESP_OK) res = httpd_resp_send_chunk(req,
                "\r\n--123456789000000000000987654321\r\n", 35);
            esp_camera_fb_return(fb);
        }
        if (res != ESP_OK) break;
    }
    return res;
}

static esp_err_t index_handler(httpd_req_t *req) {
    httpd_resp_set_type(req, "text/html");
    return httpd_resp_send(req, _INDEX_HTML, strlen(_INDEX_HTML));
}

void setup() {
    Serial.begin(115200);

    // Camera config
    camera_config_t config;
    config.ledc_channel = LEDC_CHANNEL_0;
    config.ledc_timer   = LEDC_TIMER_0;
    config.pin_d0 = Y2_GPIO_NUM; config.pin_d1 = Y3_GPIO_NUM; config.pin_d2 = Y4_GPIO_NUM;
    config.pin_d3 = Y5_GPIO_NUM; config.pin_d4 = Y6_GPIO_NUM; config.pin_d5 = Y7_GPIO_NUM;
    config.pin_d6 = Y8_GPIO_NUM; config.pin_d7 = Y9_GPIO_NUM;
    config.pin_xclk  = XCLK_GPIO_NUM; config.pin_pclk  = PCLK_GPIO_NUM;
    config.pin_vsync = VSYNC_GPIO_NUM;
