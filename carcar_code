#define PCLK_GPIO_NUM     22

// Control pins
const int SERVO_DIR_PIN    = 12;  // Direction servo (left/mid/right)
const int SERVO_FAN_PIN    = 13;  // Fan angle servo (vertical slider)
const int ESC_PIN          = 15;  // Brushless motor ESC (throttle)
const int SERVO_DRIVE1_PIN = 14;  // 360 crawl servo - spins forward
const int SERVO_DRIVE2_PIN = 2;   // 360 crawl servo - spins backward
const int LIGHT_PIN        = 4;   // Flash LED

// 50Hz PWM at 16-bit resolution: duty = pulse_us / 20000 * 65535
const int PULSE_MIN = 3277;  // 1000µs - min / full left
const int PULSE_MID = 4915;  // 1500µs - center / neutral
const int PULSE_MAX = 6554;  // 2000µs - max / full right

httpd_handle_t stream_httpd = NULL;
httpd_handle_t ctrl_httpd   = NULL;

